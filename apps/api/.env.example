# API configuration (copy to .env and fill in real values — never commit .env)

# --- Database (Supabase Postgres) ---
# Use the Supabase "Connection Pooling" (Transaction) string for serverless/Vercel,
# and the "Direct connection" string for running Prisma migrations.
# Supabase → Project Settings → Database → Connection string.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# Select the storage backend: "prisma" (Postgres/Supabase) or "memory" (dev only).
# When DATABASE_URL is set, prisma is used automatically unless DATA_BACKEND=memory.
DATA_BACKEND="prisma"

# --- Auth secrets (generate strong random values in production) ---
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# --- Seed credentials (in-memory backend only; override before any shared use) ---
SEED_SUPERADMIN_PHONE="08033328385"
SEED_SUPERADMIN_PASSWORD="blackvelvet"
SEED_SUPERADMIN_EMAIL="admin@astrobsm.local"

# --- Server ---
PORT=4000
NODE_ENV="development"
# Comma-separated list of allowed origins (your Vercel web URL in production).
CORS_ORIGIN="http://localhost:5173"
