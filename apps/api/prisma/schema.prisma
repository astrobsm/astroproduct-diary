// ASTROBSM Academy & Sales Intelligence Platform — Prisma schema
// Mirrors docs/02-database-schema.md. PostgreSQL target.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Identity & Access
// ---------------------------------------------------------------------------

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  fullName     String
  phone        String?        @unique
  locale       String         @default("en")
  status       String         @default("ACTIVE")
  requestedRoles String[]     @default([])
  approvedAt   DateTime?
  approvedById String?
  roles        UserRole[]
  enrollments  Enrollment[]
  attempts     QuizAttempt[]
  certificates Certificate[]
  interactions Interaction[]
  refreshTokens RefreshToken[]
  auditLogs    AuditLog[]
  trainer      TrainerProfile?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Role {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

// ---------------------------------------------------------------------------
// Product Knowledge
// ---------------------------------------------------------------------------

model Product {
  id           String              @id @default(cuid())
  slug         String              @unique
  name         String
  category     String
  summary      String?
  status       String              @default("PUBLISHED")
  heroImage    String?
  i18n         Json?
  ingredients  ProductIngredient[]
  sections     ProductSection[]
  faqs         ProductFAQ[]
  media        ProductMedia[]
  refLinks     ReferenceLink[]
  orderItems   OrderItem[]
  samples      SampleDistribution[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model ProductIngredient {
  id        String  @id @default(cuid())
  productId String
  name      String
  percent   String?
  role      String?
  i18n      Json?
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductSection {
  id        String  @id @default(cuid())
  productId String
  type      String
  title     String
  body      String
  order     Int     @default(0)
  i18n      Json?
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductFAQ {
  id        String  @id @default(cuid())
  productId String
  question  String
  answer    String
  order     Int     @default(0)
  i18n      Json?
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductMedia {
  id        String  @id @default(cuid())
  productId String
  kind      String // IMAGE, VIDEO, BROCHURE
  url       String
  caption   String?
  order     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Research & Evidence
// ---------------------------------------------------------------------------

model ResearchSource {
  id         String              @id @default(cuid())
  name       String              @unique
  url        String?
  references ResearchReference[]
}

model ResearchReference {
  id            String          @id @default(cuid())
  sourceId      String?
  title         String
  authors       String?
  journal       String?
  year          Int?
  doi           String?
  url           String?
  evidenceLevel String
  summary       String?
  aiSummary     String?
  source        ResearchSource? @relation(fields: [sourceId], references: [id])
  links         ReferenceLink[]
  createdAt     DateTime        @default(now())
}

model ReferenceLink {
  id          String            @id @default(cuid())
  referenceId String
  productId   String?
  topic       String?
  reference   ResearchReference @relation(fields: [referenceId], references: [id], onDelete: Cascade)
  product     Product?          @relation(fields: [productId], references: [id])
}

// ---------------------------------------------------------------------------
// Learning Management (LMS)
// ---------------------------------------------------------------------------

model Course {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  description String?
  audience    String
  level       String        @default("FOUNDATION")
  coverImage  String?
  i18n        Json?
  published   Boolean       @default(false)
  modules     Module[]
  quizzes     Quiz[]
  enrollments Enrollment[]
  certificates Certificate[]
  createdAt   DateTime      @default(now())
}

model Module {
  id       String   @id @default(cuid())
  courseId String
  title    String
  order    Int      @default(0)
  i18n     Json?
  lessons  Lesson[]
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Lesson {
  id          String  @id @default(cuid())
  moduleId    String
  title       String
  contentType String  @default("TEXT")
  body        String?
  mediaUrl    String?
  order       Int     @default(0)
  i18n        Json?
  quizzes     Quiz[]
  module      Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Quiz {
  id        String        @id @default(cuid())
  lessonId  String?
  courseId  String?
  title     String
  passScore Int           @default(70)
  questions Question[]
  attempts  QuizAttempt[]
  lesson    Lesson?       @relation(fields: [lessonId], references: [id])
  course    Course?       @relation(fields: [courseId], references: [id])
}

model Question {
  id          String  @id @default(cuid())
  quizId      String
  prompt      String
  type        String  @default("SINGLE")
  options     Json
  correct     Json
  explanation String?
  i18n        Json?
  quiz        Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  status      String    @default("ACTIVE")
  progressPct Int       @default(0)
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  quizId    String
  score     Int
  passed    Boolean
  answers   Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model Certificate {
  id       String   @id @default(cuid())
  userId   String
  courseId String
  serial   String   @unique
  issuedAt DateTime @default(now())
  pdfUrl   String?
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Training of Trainers (TOT)
// ---------------------------------------------------------------------------

model Competency {
  id          String                 @id @default(cuid())
  key         String                 @unique
  name        String
  description String?
  rubric      Json?
  assessments CompetencyAssessment[]
}

model TrainerProfile {
  id          String                 @id @default(cuid())
  userId      String                 @unique
  status      String                 @default("ACTIVE")
  bio         String?
  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessments CompetencyAssessment[]
  badges      TrainerBadge[]
}

model CompetencyAssessment {
  id               String         @id @default(cuid())
  trainerProfileId String
  competencyId     String
  score            Int
  assessorId       String?
  notes            String?
  createdAt        DateTime       @default(now())
  trainer          TrainerProfile @relation(fields: [trainerProfileId], references: [id], onDelete: Cascade)
  competency       Competency     @relation(fields: [competencyId], references: [id])
}

model TrainerBadge {
  id               String         @id @default(cuid())
  trainerProfileId String
  badgeKey         String
  awardedAt        DateTime       @default(now())
  trainer          TrainerProfile @relation(fields: [trainerProfileId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Hospitals / Geography
// ---------------------------------------------------------------------------

model Country {
  id        String             @id @default(cuid())
  iso2      String             @unique
  name      String
  language  String             @default("en")
  zones     GeopoliticalZone[]
  states    StateRegion[]
  facilities Facility[]
}

model GeopoliticalZone {
  id        String        @id @default(cuid())
  countryId String
  name      String
  country   Country       @relation(fields: [countryId], references: [id], onDelete: Cascade)
  states    StateRegion[]
  facilities Facility[]
}

model StateRegion {
  id         String            @id @default(cuid())
  countryId  String
  zoneId     String?
  name       String
  code       String?
  country    Country           @relation(fields: [countryId], references: [id], onDelete: Cascade)
  zone       GeopoliticalZone? @relation(fields: [zoneId], references: [id])
  lgas       Lga[]
  facilities Facility[]
}

model Lga {
  id        String      @id @default(cuid())
  stateId   String
  name      String
  state     StateRegion @relation(fields: [stateId], references: [id], onDelete: Cascade)
  facilities Facility[]
}

model Facility {
  id         String            @id @default(cuid())
  countryId  String
  stateId    String?
  lgaId      String?
  zoneId     String?
  name       String
  type       String
  address    String?
  latitude   Float?
  longitude  Float?
  phone      String?
  email      String?
  website    String?
  source     String? // provenance — required for verified imports
  verifiedAt DateTime?
  createdAt  DateTime          @default(now())
  country    Country           @relation(fields: [countryId], references: [id])
  state      StateRegion?      @relation(fields: [stateId], references: [id])
  lga        Lga?              @relation(fields: [lgaId], references: [id])
  zone       GeopoliticalZone? @relation(fields: [zoneId], references: [id])
  contacts   Contact[]
  interactions Interaction[]
  orders     Order[]
}

model ImportBatch {
  id          String   @id @default(cuid())
  entity      String
  sourceFile  String?
  rows        Int      @default(0)
  accepted    Int      @default(0)
  rejected    Int      @default(0)
  createdById String?
  createdAt   DateTime @default(now())
}

// ---------------------------------------------------------------------------
// CRM
// ---------------------------------------------------------------------------

model Contact {
  id           String        @id @default(cuid())
  facilityId   String?
  fullName     String
  title        String?
  role         String
  phone        String?
  email        String?
  consentAt    DateTime?
  i18n         Json?
  facility     Facility?     @relation(fields: [facilityId], references: [id])
  interactions Interaction[]
  followUps    FollowUp[]
  leads        Lead[]
  attendees    SeminarAttendee[]
  distributor  Distributor?
  samples      SampleDistribution[]
}

model Interaction {
  id         String    @id @default(cuid())
  contactId  String?
  facilityId String?
  userId     String
  type       String // CALL, VISIT, MEETING, EMAIL, SEMINAR
  channel    String?
  notes      String?
  occurredAt DateTime  @default(now())
  contact    Contact?  @relation(fields: [contactId], references: [id])
  facility   Facility? @relation(fields: [facilityId], references: [id])
  user       User      @relation(fields: [userId], references: [id])
  followUps  FollowUp[]
}

model FollowUp {
  id            String       @id @default(cuid())
  interactionId String?
  contactId     String?
  assigneeId    String?
  dueAt         DateTime?
  status        String       @default("OPEN")
  notes         String?
  interaction   Interaction? @relation(fields: [interactionId], references: [id])
  contact       Contact?     @relation(fields: [contactId], references: [id])
}

// ---------------------------------------------------------------------------
// Campaigns & Seminars
// ---------------------------------------------------------------------------

model Campaign {
  id         String   @id @default(cuid())
  name       String
  ownerId    String?
  territory  String?
  startDate  DateTime?
  endDate    DateTime?
  status     String   @default("PLANNED")
  objectives Json?
  seminars   Seminar[]
  leads      Lead[]
  samples    SampleDistribution[]
}

model Seminar {
  id          String            @id @default(cuid())
  campaignId  String?
  title       String
  type        String // CME, WORKSHOP, PRODUCT_LAUNCH
  facilityId  String?
  venue       String?
  scheduledAt DateTime?
  organizerId String?
  status      String            @default("SCHEDULED")
  campaign    Campaign?         @relation(fields: [campaignId], references: [id])
  attendees   SeminarAttendee[]
  leads       Lead[]
  samples     SampleDistribution[]
}

model SeminarAttendee {
  id         String   @id @default(cuid())
  seminarId  String
  contactId  String?
  name       String?
  role       String?
  signedInAt DateTime @default(now())
  seminar    Seminar  @relation(fields: [seminarId], references: [id], onDelete: Cascade)
  contact    Contact? @relation(fields: [contactId], references: [id])
}

model Lead {
  id         String    @id @default(cuid())
  seminarId  String?
  campaignId String?
  contactId  String?
  source     String?
  stage      String    @default("NEW")
  value      Float?
  ownerId    String?
  createdAt  DateTime  @default(now())
  seminar    Seminar?  @relation(fields: [seminarId], references: [id])
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  contact    Contact?  @relation(fields: [contactId], references: [id])
}

model SampleDistribution {
  id                String    @id @default(cuid())
  seminarId         String?
  campaignId        String?
  productId         String
  quantity          Int
  recipientContactId String?
  userId            String?
  givenAt           DateTime  @default(now())
  seminar           Seminar?  @relation(fields: [seminarId], references: [id])
  campaign          Campaign? @relation(fields: [campaignId], references: [id])
  product           Product   @relation(fields: [productId], references: [id])
  recipient         Contact?  @relation(fields: [recipientContactId], references: [id])
}

// ---------------------------------------------------------------------------
// Sales Intelligence
// ---------------------------------------------------------------------------

model Distributor {
  id        String  @id @default(cuid())
  name      String
  contactId String? @unique
  territory String?
  tier      String?
  status    String  @default("ACTIVE")
  contact   Contact? @relation(fields: [contactId], references: [id])
  orders    Order[]
}

model Order {
  id            String       @id @default(cuid())
  distributorId String?
  facilityId    String?
  ownerId       String?
  status        String       @default("DRAFT")
  currency      String       @default("NGN")
  total         Float        @default(0)
  placedAt      DateTime     @default(now())
  distributor   Distributor? @relation(fields: [distributorId], references: [id])
  facility      Facility?    @relation(fields: [facilityId], references: [id])
  items         OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Float
  lineTotal Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model TerritoryTarget {
  id          String  @id @default(cuid())
  territory   String
  period      String
  targetValue Float
  productId   String?
}

model StockForecast {
  id              String @id @default(cuid())
  productId       String
  territory       String
  period          String
  projectedDemand Float
  basis           Json?
}
